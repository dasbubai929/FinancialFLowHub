---
import Layout from "../../../layouts/Layout.astro";
import BuyBorrowDieCalculator from "../../../components/BuyBorrowDieCalculator.astro";
---

<Layout 
  title="UK Buy, Borrow, Die Lombard Loan Calculator — Lombard Loan vs Capital Gains Tax Tool | TaxDebtWealthSuite"
  description="Model the Buy, Borrow, Die strategy free in the UK. Compare Lombard loan borrowing costs vs capital gains tax, check your margin call risk, and see your 1-year net wealth advantage."
  ogImage="https://taxdebtwealthsuite.com/images/og-buy-borrow-die.png"
>
  <link rel="alternate" hreflang="x-default" href="https://taxdebtwealthsuite.com/buy-borrow-die-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-us" href="https://taxdebtwealthsuite.com/buy-borrow-die-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-gb" href="https://taxdebtwealthsuite.com/buy-borrow-die-calculator/uk/" slot="head" />
  <link rel="alternate" hreflang="en-ca" href="https://taxdebtwealthsuite.com/buy-borrow-die-calculator/canada/" slot="head" />
  <link rel="alternate" hreflang="en-au" href="https://taxdebtwealthsuite.com/buy-borrow-die-calculator/australia/" slot="head" />

  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "SoftwareApplication",
        "name": "UK Buy, Borrow, Die Lombard Loan Calculator",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        },
        "description": "Model the Buy, Borrow, Die strategy free in the UK. Compare Lombard loan borrowing costs vs capital gains tax, check your margin call risk, and see your 1-year net wealth advantage."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [{
          "@type": "Question",
          "name": "What are the risks of borrowing against your stock portfolio (Lombard Loan)?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A Lombard Loan carries three primary risks: (1) Margin calls — if your portfolio value drops significantly, your lender can demand immediate repayment or force liquidation of assets; (2) Interest rate risk — Lombard rates are typically variable and linked to benchmark rates like SONIA, meaning costs rise in high-rate environments; and (3) Collateral concentration — pledging a single-asset portfolio amplifies downside exposure. The standard maintenance LTV threshold is 60% to 70% — meaning a portfolio decline of more than 30% above your loan amount can trigger a forced sale."
          }
        }]
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://taxdebtwealthsuite.com/"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Buy, Borrow, Die Calculator",
            "item": "https://taxdebtwealthsuite.com/buy-borrow-die-calculator/"
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": "United Kingdom",
            "item": "https://taxdebtwealthsuite.com/buy-borrow-die-calculator/uk/"
          }
        ]
      }
    ]
  }
  </script>

  <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-10">
    
    <!-- Title Section -->
    <div class="mb-8 text-center sm:text-left">
      <h1 class="text-3xl font-extrabold text-white tracking-tight font-sans">
        UK Buy, Borrow, Die Calculator: Lombard Loan vs Selling Assets
      </h1>
      <p class="text-sm text-slate-400 mt-2 max-w-2xl leading-relaxed">
        Model Securities-Based Lines of Credit (SBLOC) via Lombard lending in the UK, comparing interest costs against Capital Gains Tax drag.
      </p>
      <div class="mt-4 text-xs text-slate-400">
        Switch to another country variant: 
        <a href="/buy-borrow-die-calculator/" class="text-[#00F5D4] hover:underline">United States (Default)</a> | 
        <span class="text-slate-300 font-semibold">United Kingdom</span> | 
        <a href="/buy-borrow-die-calculator/canada/" class="text-[#00F5D4] hover:underline">Canada (Margin Loan)</a> | 
        <a href="/buy-borrow-die-calculator/australia/" class="text-[#00F5D4] hover:underline">Australia (Margin Lending)</a>
      </div>
    </div>

    <!-- Calculator Component -->
    <BuyBorrowDieCalculator defaultCurrency="GBP" />

    <!-- Explainer Content -->
    <div class="border-t border-slate-800/60 mt-12 bg-gradient-to-b from-slate-950 to-slate-950/95">
      <div class="max-w-4xl mx-auto py-16">
        <section aria-labelledby="bbd-guide-heading">
          <div class="mb-6">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 mb-4">Portfolio Strategy (UK)</span>
            <h2 id="bbd-guide-heading" class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight leading-snug">
              Leveraging the "Buy, Borrow, Die" Strategy in the UK
            </h2>
            <p class="mt-3 text-slate-400 text-sm leading-relaxed">
              The Buy, Borrow, Die strategy has become increasingly popular among high-net-worth investors in the United Kingdom, where capital gains tax (CGT) rates make liquidating stock portfolios highly expensive. Instead of selling shares and triggering a costly CGT event, investors leverage Lombard loans—the UK equivalent of a Securities-Based Line of Credit (SBLOC). Under HMRC guidelines, borrowing against your investment portfolio is not classified as a taxable distribution, meaning you can access liquidity completely tax-free.
            </p>
          </div>

          <div class="space-y-6 text-sm text-slate-400 leading-relaxed">
            <article>
              <h3 class="text-base font-bold text-slate-100 mb-2">How Lombard Loans Avoid CGT Drag</h3>
              <p>
                Lombard lending in the UK typically operates under variable interest rates pegged to benchmark rates like SONIA. Because you are borrowing against volatile assets like equities or bonds, UK financial institutions enforce strict Loan-to-Value (LTV) limits, often requiring a buffer zone. If your LTV exceeds the maintenance margin (usually around 60% to 70%), a margin call will be triggered, forcing you to deposit cash or sell assets at a loss.
              </p>
              <p class="mt-3">
                By using a Lombard loan, you avoid the capital gains tax drag that occurs when you sell stocks. In the UK, liquidating a large position can push you into the higher CGT bracket, costing up to 20% on shares (or more depending on the asset class). Pledging your assets as collateral allows your portfolio to compound uninterrupted, maximizing your long-term wealth. However, variable borrowing rates and downside market shocks mean UK investors must practice conservative leverage management, maintaining LTVs below 30% to shield against margin calls.
              </p>
            </article>

            <article>
              <h3 class="text-base font-bold text-slate-100 mb-2">Key Risk Rules for UK Borrowers</h3>
              <p>
                Unlike the United States, which offers a perpetual step-up in cost basis upon death, the UK's capital gains tax at death is handled differently, often integrated with Inheritance Tax (IHT) considerations. Under UK tax law, assets passed to a spouse are CGT-free, and IHT planning may allow outstanding Lombard debt to reduce the taxable value of the estate. Conservative leverage buffers are vital to preventing forced portfolio liquidations at sub-optimal prices during market drawdowns. Before leveraging stock portfolio debt, ensure your high-interest personal liabilities are resolved using our <a href="/debt-payoff-calculator/uk/" class="text-[#00F5D4] hover:underline font-semibold">debt snowball vs avalanche planner</a>, and if your borrowing is aimed at funding a new business, compare incorporation benefits with the <a href="/s-corp-tax-calculator/uk/" class="text-[#00F5D4] hover:underline font-semibold">Ltd Company vs sole trader tax calculator</a>.
              </p>
            </article>
          </div>

          <!-- FAQ Accordion -->
          <div class="mt-12 border-t border-slate-800/80 pt-10">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-amber-500/10 text-amber-400 border border-amber-500/20 mb-4">FAQ</span>
            <h3 class="text-xl font-bold text-white mb-6">Frequently Asked Questions</h3>
            <div class="faq-item border border-[#1E294B] rounded-lg overflow-hidden bg-[#141C32]">
              <button
                class="faq-trigger w-full flex items-center justify-between px-6 py-5 text-left group cursor-pointer"
                aria-expanded="false"
                onclick="this.setAttribute('aria-expanded', this.getAttribute('aria-expanded')==='true' ? 'false' : 'true'); this.nextElementSibling.classList.toggle('hidden');"
              >
                <span class="text-sm font-semibold text-white pr-4">What are the risks of borrowing against your stock portfolio (Lombard Loan)?</span>
                <svg class="h-5 w-5 text-slate-500 flex-shrink-0 transition-transform duration-200 group-[&[aria-expanded=true]]:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div class="hidden px-6 pb-6">
                <p class="text-sm text-slate-400 leading-relaxed">
                  A Lombard Loan carries three primary risks: <strong class="text-slate-300">(1) Margin calls</strong> — if your portfolio value drops significantly, your lender can demand immediate repayment or force liquidation of assets; <strong class="text-slate-300">(2) Interest rate risk</strong> — Lombard rates are typically variable and linked to benchmark rates like SONIA, meaning costs rise in high-rate environments; and <strong class="text-slate-300">(3) Collateral concentration</strong> — pledging a single-asset portfolio amplifies downside exposure. The standard maintenance LTV threshold is 60% to 70% — meaning a portfolio decline of more than 30% above your loan amount can trigger a forced sale.
                </p>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>
</Layout>
