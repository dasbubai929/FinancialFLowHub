---
import Layout from "../../../layouts/Layout.astro";
import BuyBorrowDieCalculator from "../../../components/BuyBorrowDieCalculator.astro";
---

<Layout 
  title="Canada Buy, Borrow, Die Portfolio Leverage Calculator — Margin Loan vs Capital Gains Tax Tool | TaxDebtWealthSuite"
  description="Model the Buy, Borrow, Die strategy free in Canada. Compare margin loan borrowing costs vs capital gains tax, check your margin call risk, and see your 1-year net wealth advantage."
  ogImage="https://taxdebtwealthsuite.com/images/og-buy-borrow-die.png"
>
  <link rel="alternate" hreflang="x-default" href="https://taxdebtwealthsuite.com/buy-borrow-die-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-us" href="https://taxdebtwealthsuite.com/buy-borrow-die-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-gb" href="https://taxdebtwealthsuite.com/buy-borrow-die-calculator/uk/" slot="head" />
  <link rel="alternate" hreflang="en-ca" href="https://taxdebtwealthsuite.com/buy-borrow-die-calculator/canada/" slot="head" />
  <link rel="alternate" hreflang="en-au" href="https://taxdebtwealthsuite.com/buy-borrow-die-calculator/australia/" slot="head" />

  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "SoftwareApplication",
        "name": "Canada Buy, Borrow, Die Portfolio Leverage Calculator",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        },
        "description": "Model the Buy, Borrow, Die strategy free in Canada. Compare margin loan borrowing costs vs capital gains tax, check your margin call risk, and see your 1-year net wealth advantage."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [{
          "@type": "Question",
          "name": "What are the risks of borrowing against your stock portfolio (SBLOC / Margin Loan)?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An SBLOC or Margin Loan carries three primary risks: (1) Margin calls — if your portfolio value drops significantly, your lender can demand immediate repayment or force liquidation of assets; (2) Interest rate risk — margin loan rates are variable, meaning borrowing costs rise in high-rate environments; and (3) Collateral concentration — pledging a single-asset portfolio amplifies downside exposure. The standard maintenance LTV threshold is 70% — meaning a portfolio decline of more than 30% above your loan amount can trigger a forced sale."
          }
        }]
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://taxdebtwealthsuite.com/"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Buy, Borrow, Die Calculator",
            "item": "https://taxdebtwealthsuite.com/buy-borrow-die-calculator/"
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": "Canada",
            "item": "https://taxdebtwealthsuite.com/buy-borrow-die-calculator/canada/"
          }
        ]
      }
    ]
  }
  </script>

  <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-10">
    
    <!-- Title Section -->
    <div class="mb-8 text-center sm:text-left">
      <h1 class="text-3xl font-extrabold text-white tracking-tight font-sans">
        Canada Buy, Borrow, Die Calculator: Margin Loan vs Selling Assets
      </h1>
      <p class="text-sm text-slate-400 mt-2 max-w-2xl leading-relaxed">
        Model Securities-Based Lines of Credit (SBLOC) and margin loans in Canada, analyzing the impact of interest costs vs capital gains inclusion rates.
      </p>
      <div class="mt-4 text-xs text-slate-400">
        Switch to another country variant: 
        <a href="/buy-borrow-die-calculator/" class="text-[#00F5D4] hover:underline">United States (Default)</a> | 
        <a href="/buy-borrow-die-calculator/uk/" class="text-[#00F5D4] hover:underline">United Kingdom (Lombard Loan)</a> | 
        <span class="text-slate-300 font-semibold">Canada</span> | 
        <a href="/buy-borrow-die-calculator/australia/" class="text-[#00F5D4] hover:underline">Australia (Margin Lending)</a>
      </div>
    </div>

    <!-- Calculator Component -->
    <BuyBorrowDieCalculator defaultCurrency="CAD" />

    <!-- Explainer Content -->
    <div class="border-t border-slate-800/60 mt-12 bg-gradient-to-b from-slate-950 to-slate-950/95">
      <div class="max-w-4xl mx-auto py-16">
        <section aria-labelledby="bbd-guide-heading">
          <div class="mb-6">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 mb-4">Portfolio Strategy (Canada)</span>
            <h2 id="bbd-guide-heading" class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight leading-snug">
              Leveraging the "Buy, Borrow, Die" Strategy in Canada
            </h2>
            <p class="mt-3 text-slate-400 text-sm leading-relaxed">
              In Canada, the Buy, Borrow, Die strategy is a sophisticated wealth management technique utilized to bypass the heavy tax burden of capital gains realization. When Canadian investors sell appreciated equity inside a non-registered account, 50% (and recently increased to 66.67% for gains over $250,000) of the capital gain is added to their personal taxable income. This capital gains tax drag can severely stunt portfolio growth.
            </p>
          </div>

          <div class="space-y-6 text-sm text-slate-400 leading-relaxed">
            <article>
              <h3 class="text-base font-bold text-slate-100 mb-2">How SBLOCs Bypass Capital Gains Realization</h3>
              <p>
                To mitigate this, investors turn to Securities-Based Lines of Credit (SBLOC) or margin lending facilities from Canadian financial institutions. Borrowing against a portfolio allows you to withdraw cash for real estate purchases, personal expenses, or reinvestment without triggering a taxable event. The CRA does not tax borrowed capital, making this an effective strategy for tax-free liquidity.
              </p>
              <p class="mt-3">
                However, Canadian leverage strategies demand caution. Lenders require margin maintenance buffers, and the volatility of Canadian equity markets can result in sudden margin calls. If your Loan-to-Value (LTV) ratio surpasses the threshold set by your broker, they can liquidate your assets without notice, turning a paper loss into a permanent, taxable capital loss. Furthermore, while interest on loans used to generate income (like buying dividend-paying stocks) is tax-deductible in Canada under section 20(1)(c) of the Income Tax Act, interest on borrowing for personal consumption (the core of the "Borrow" phase) is not deductible. Canadian investors must model these variables carefully to ensure interest rates do not exceed their tax savings.
              </p>
            </article>

            <article>
              <h3 class="text-base font-bold text-slate-100 mb-2">Stepped-Up Basis Equivalency in Canada</h3>
              <p>
                Unlike the US stepped-up cost basis rule, Canada triggers a "deemed disposition" at death, meaning you are treated as having sold all your assets at fair market value immediately before death, which can trigger a massive terminal tax bill. SBLOC interest structures and estate-linked life insurance policies are often integrated by Canadian wealth planners to offset this deemed disposition liability, preserving the underlying capital base for the next generation. Before leveraging stock portfolio debt, ensure your high-interest personal liabilities are resolved using our <a href="/debt-payoff-calculator/canada/" class="text-[#00F5D4] hover:underline font-semibold">debt snowball vs avalanche planner</a>, and if your borrowing is aimed at funding a new business, compare incorporation benefits with the <a href="/s-corp-tax-calculator/canada/" class="text-[#00F5D4] hover:underline font-semibold">CCPC vs sole proprietor tax calculator</a>.
              </p>
            </article>
          </div>

          <!-- FAQ Accordion -->
          <div class="mt-12 border-t border-slate-800/80 pt-10">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-amber-500/10 text-amber-400 border border-amber-500/20 mb-4">FAQ</span>
            <h3 class="text-xl font-bold text-white mb-6">Frequently Asked Questions</h3>
            <div class="faq-item border border-[#1E294B] rounded-lg overflow-hidden bg-[#141C32]">
              <button
                class="faq-trigger w-full flex items-center justify-between px-6 py-5 text-left group cursor-pointer"
                aria-expanded="false"
                onclick="this.setAttribute('aria-expanded', this.getAttribute('aria-expanded')==='true' ? 'false' : 'true'); this.nextElementSibling.classList.toggle('hidden');"
              >
                <span class="text-sm font-semibold text-white pr-4">What are the risks of borrowing against your stock portfolio (SBLOC / Margin Loan)?</span>
                <svg class="h-5 w-5 text-slate-500 flex-shrink-0 transition-transform duration-200 group-[&[aria-expanded=true]]:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div class="hidden px-6 pb-6">
                <p class="text-sm text-slate-400 leading-relaxed">
                  An SBLOC or Margin Loan carries three primary risks: <strong class="text-slate-300">(1) Margin calls</strong> — if your portfolio value drops significantly, your lender can demand immediate repayment or force liquidation of assets; <strong class="text-slate-300">(2) Interest rate risk</strong> — margin loan rates are variable, meaning borrowing costs rise in high-rate environments; and <strong class="text-slate-300">(3) Collateral concentration</strong> — pledging a single-asset portfolio amplifies downside exposure. The standard maintenance LTV threshold is 70% — meaning a portfolio decline of more than 30% above your loan amount can trigger a forced sale.
                </p>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>
</Layout>
