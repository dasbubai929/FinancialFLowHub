---
import Layout from "../../layouts/Layout.astro";
import BuyBorrowDieCalculator from "../../components/BuyBorrowDieCalculator.astro";
---

<Layout 
  title="Buy, Borrow, Die Calculator — SBLOC vs Capital Gains Tax Tool | TaxDebtWealthSuite"
  description="Model the Buy, Borrow, Die strategy free. Compare SBLOC borrowing costs vs capital gains tax, check your margin call risk, and see your 1-year net wealth advantage."
  ogImage="https://taxdebtwealthsuite.com/images/og-buy-borrow-die.png"
>
  <link rel="alternate" hreflang="x-default" href="https://taxdebtwealthsuite.com/buy-borrow-die-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-us" href="https://taxdebtwealthsuite.com/buy-borrow-die-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-gb" href="https://taxdebtwealthsuite.com/buy-borrow-die-calculator/uk/" slot="head" />
  <link rel="alternate" hreflang="en-ca" href="https://taxdebtwealthsuite.com/buy-borrow-die-calculator/canada/" slot="head" />
  <link rel="alternate" hreflang="en-au" href="https://taxdebtwealthsuite.com/buy-borrow-die-calculator/australia/" slot="head" />

  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "SoftwareApplication",
        "name": "Buy, Borrow, Die Calculator",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        },
        "description": "Model the Buy, Borrow, Die strategy free. Compare SBLOC borrowing costs vs capital gains tax, check your margin call risk, and see your 1-year net wealth advantage."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [{
          "@type": "Question",
          "name": "What are the risks of borrowing against your stock portfolio (SBLOC)?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A Securities-Based Line of Credit (SBLOC) carries three primary risks: (1) Margin calls — if your portfolio value drops significantly, your lender can demand immediate repayment or force liquidation of assets; (2) Interest rate risk — SBLOC rates are typically variable and linked to SOFR, meaning costs rise in high-rate environments; and (3) Collateral concentration — pledging a single-asset portfolio amplifies downside exposure. The standard maintenance LTV threshold is 70% — meaning a portfolio decline of more than 30% above your loan amount can trigger a forced sale."
          }
        }]
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://taxdebtwealthsuite.com/"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Buy, Borrow, Die Calculator",
            "item": "https://taxdebtwealthsuite.com/buy-borrow-die-calculator/"
          }
        ]
      }
    ]
  }
  </script>

  <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-10">
    
    <!-- Title Section -->
    <div class="mb-8 text-center sm:text-left">
      <h1 class="text-3xl font-extrabold text-white tracking-tight font-sans">
        Buy, Borrow, Die Calculator: SBLOC vs Selling Assets
      </h1>
      <p class="text-sm text-slate-400 mt-2 max-w-2xl leading-relaxed">
        Model Securities-Based Lines of Credit (SBLOC) vs. asset liquidation to analyze interest cost, tax drag savings, and margin call safety buffers.
      </p>
      <div class="mt-4 text-xs text-slate-400">
        Switch to another country variant: 
        <span class="text-slate-300 font-semibold">United States (Default)</span> | 
        <a href="/buy-borrow-die-calculator/uk/" class="text-[#00F5D4] hover:underline">United Kingdom (Lombard Loan)</a> | 
        <a href="/buy-borrow-die-calculator/canada/" class="text-[#00F5D4] hover:underline">Canada (Margin Loan)</a> | 
        <a href="/buy-borrow-die-calculator/australia/" class="text-[#00F5D4] hover:underline">Australia (Margin Lending)</a>
      </div>
    </div>

    <!-- Calculator Component -->
    <BuyBorrowDieCalculator defaultCurrency="USD" />

    <!-- Explainer Content -->
    <div class="border-t border-slate-800/60 mt-12 bg-gradient-to-b from-slate-950 to-slate-950/95">
      <div class="max-w-4xl mx-auto py-16">
        <section aria-labelledby="bbd-guide-heading">
          <div class="mb-6">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 mb-4">Portfolio Strategy</span>
            <h2 id="bbd-guide-heading" class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight leading-snug">
              Demystifying the "Buy, Borrow, Die" Financial Strategy
            </h2>
            <p class="mt-3 text-slate-400 text-sm leading-relaxed">
              The <strong class="text-slate-200">portfolio line of credit tax strategy</strong> — colloquially known as "Buy, Borrow, Die" — is a wealth preservation technique used by high-net-worth individuals and family offices to generate liquidity from appreciated assets without triggering a taxable capital gains event.
            </p>
          </div>

          <div class="space-y-6 text-sm text-slate-400 leading-relaxed">
            <article>
              <h3 class="text-base font-bold text-slate-100 mb-2">How the SBLOC Strategy Works</h3>
              <p>
                A <strong class="text-slate-300">Securities-Based Line of Credit (SBLOC)</strong> allows investors to pledge their investment portfolio — equities, ETFs, mutual funds, or bonds — as collateral against a revolving credit facility. Rather than selling appreciated stock and paying 20%–37% in combined federal capital gains and income tax (depending on your bracket), the investor simply <strong class="text-slate-300">borrows against stocks to avoid capital gains</strong> and uses that cash for living expenses, real estate purchases, or reinvestment.
              </p>
              <p class="mt-3">
                The strategy becomes generational when paired with the IRS stepped-up cost basis rule: at death, heirs inherit assets at their current market value, completely eliminating the embedded capital gain. This is the "Die" component — the tax liability is legally erased at death, never collected.
              </p>
            </article>

            <article>
              <h3 class="text-base font-bold text-slate-100 mb-2">SBLOC Interest Rates vs. Capital Gains Tax — The Break-Even Math</h3>
              <p>
                The core <strong class="text-slate-300">SBLOC interest rates vs capital gains tax</strong> comparison is straightforward: if your long-term capital gains tax rate (typically 15%–20% federally, plus state taxes up to 13.3% in California) exceeds the annualized interest cost of your SBLOC (typically Prime + 1%–3%, or roughly 6%–9% in 2026), borrowing generates a structural net saving on every dollar of liquidity generated. In the UK, where Capital Gains Tax reaches 24% for higher-rate taxpayers on investment gains above the £3,000 annual exempt amount, the SBLOC equivalent — often called a <em>Lombard Loan</em> — offers similar advantages.
              </p>
            </article>

            <article>
              <h3 class="text-base font-bold text-slate-100 mb-2">Inherent Risks: Margin Calls and LTV Thresholds</h3>
              <p>
                The strategy is not without material risks. Most SBLOC lenders enforce a <strong class="text-slate-300">Loan-to-Value (LTV) maintenance threshold</strong> of 65%–75%. If the underlying portfolio declines in value — as all equity portfolios periodically do — the lender can issue a margin call, requiring the borrower to either deposit additional collateral or repay a portion of the loan within 24–72 hours. In a severe market downturn, this can force an investor to sell assets at precisely the worst prices — the very scenario the strategy was designed to avoid.
              </p>
              <p class="mt-3">
                Our <strong class="text-slate-300">Buy, Borrow, Die calculator</strong> above models this in real time, showing your current LTV, the price drop buffer before a margin call is triggered, and a color-coded risk meter (Green &lt;30% LTV, Amber 30%–50%, Red &gt;50%) to help you maintain a safe leverage envelope. Before leveraging stock portfolio debt, ensure your high-interest personal liabilities are resolved using our <a href="/debt-payoff-calculator/" class="text-[#00F5D4] hover:underline font-semibold">debt snowball vs avalanche planner</a>, and if your borrowing is aimed at funding a new business, compare incorporation benefits with the <a href="/s-corp-tax-calculator/" class="text-[#00F5D4] hover:underline font-semibold">S-Corp vs sole proprietor tax calculator</a>.
              </p>
            </article>
          </div>

          <!-- FAQ Accordion -->
          <div class="mt-12 border-t border-slate-800/80 pt-10">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-amber-500/10 text-amber-400 border border-amber-500/20 mb-4">FAQ</span>
            <h3 class="text-xl font-bold text-white mb-6">Frequently Asked Questions</h3>
            <div class="faq-item border border-[#1E294B] rounded-lg overflow-hidden bg-[#141C32]">
              <button
                class="faq-trigger w-full flex items-center justify-between px-6 py-5 text-left group cursor-pointer"
                aria-expanded="false"
                onclick="this.setAttribute('aria-expanded', this.getAttribute('aria-expanded')==='true' ? 'false' : 'true'); this.nextElementSibling.classList.toggle('hidden');"
              >
                <span class="text-sm font-semibold text-white pr-4">What are the risks of borrowing against your stock portfolio (SBLOC)?</span>
                <svg class="h-5 w-5 text-slate-500 flex-shrink-0 transition-transform duration-200 group-[&[aria-expanded=true]]:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div class="hidden px-6 pb-6">
                <p class="text-sm text-slate-400 leading-relaxed">
                  A Securities-Based Line of Credit (SBLOC) carries three primary risks: <strong class="text-slate-300">(1) Margin calls</strong> — if your portfolio value drops significantly, your lender can demand immediate repayment or force liquidation of assets; <strong class="text-slate-300">(2) Interest rate risk</strong> — SBLOC rates are typically variable and linked to SOFR, meaning costs rise in high-rate environments; and <strong class="text-slate-300">(3) Collateral concentration</strong> — pledging a single-asset portfolio amplifies downside exposure. The standard maintenance LTV threshold is 70% — meaning a portfolio decline of more than 30% above your loan amount can trigger a forced sale.
                </p>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>
</Layout>
